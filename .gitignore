!/legacy/artifacts/manim/manim_voiceover_experiment/voiceover_bookmark_demo.py

# Current gen-2 pipeline render outputs
/video/output/

# Manim CLI default output directory
media/

# Authoring R&D run outputs + handout render screenshots (regenerable; contain raw model responses)
authoring/**/out/
handout/html/_render/out/

# Third-party reference scans (copyrighted; not for distribution)
stewart/

