.venv/
.venv_test/
.deps/
.deps_f5/
.deps_voiceover/

# Secrets / API keys (never commit — Gemini etc. read the key from the environment)
.env
.env.*
*.key

# Local caches and temp files
.cache/
.pip-cache/
.pip-cache-f5/
.tmp/
*.tmp
*.bak
*.orig
# Ad-hoc PDF-page previews (pdftoppm, pdf2image, etc.)
tmp_*.png
tmp_*.jpg
tmp_*.pdf

# Editor and IDE metadata
.vscode/
.idea/
*.code-workspace

# Claude Code: ignore personal/volatile state, but track shared project assets
# (agents, commands, skills, output styles, shared settings). New shared assets
# under a whitelisted dir are tracked automatically — no `git add -f` needed.
# Ignored: settings.local.json (personal), worktrees/ (git work-trees), launch.json
# (ad-hoc local QA), scheduled_tasks.lock, and anything else under .claude/.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/skills/
!.claude/output-styles/
!.claude/settings.json

# OS metadata
Thumbs.db
Desktop.ini
.DS_Store

# LaTeX 成品夾（handout/latex/dist/<ch>/＝一 tex 一 pdf，皆進版控）——
# 成品 PDF 是 *.pdf 全域忽略的例外；編譯殘渣（若有人用非 latexmk 流程）不進
!handout/latex/dist/**/*.pdf
handout/latex/dist/**/*.aux
handout/latex/dist/**/*.log
handout/latex/dist/**/*.fls
handout/latex/dist/**/*.fdb_latexmk
handout/latex/dist/**/*.synctex.gz
handout/latex/dist/**/*.out
handout/latex/dist/**/*.toc
