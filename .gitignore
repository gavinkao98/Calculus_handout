handout/latex/build/

# Generated media pipeline outputs (frozen gen-0/gen-1, now archived under legacy/)
/legacy/artifacts/*
!/legacy/artifacts/scripts/
!/legacy/artifacts/slides/
!/legacy/artifacts/manim/
/legacy/artifacts/scripts/*
!/legacy/artifacts/scripts/*_final.md
