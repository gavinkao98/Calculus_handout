{
  "meta": {
    "name": "NTU 數學組 — Calculus Video System (Direction B · Blueprint Grid)",
    "canvas": { "width": 1920, "height": 1080, "aspect": "16:9" },
    "note": "Per-video flow: intro (light) -> teaching frames (dark) -> outro (light). Light = brand moments, dark = teaching. section_transition is deprecated (one section = one video)."
  },

  "color": {
    "teaching_dark_canvas": {
      "bg":        { "hex": "#0a0e1a", "use": "deep navy-black canvas (teaching frames)" },
      "bg_soft":   { "hex": "#121a2e", "use": "elevated panel / sidebar block" },
      "primary":   { "hex": "#eef0f7", "use": "headings / neutral display (cool off-white)" },
      "secondary": { "hex": "#4cc9f0", "use": "definitions, propositions (cool cyan)" },
      "accent":    { "hex": "#f4b13a", "use": "theorems, key emphasis (warm gold)" },
      "math":      { "hex": "#7df9ff", "use": "math expressions (electric blue)" },
      "warning":   { "hex": "#ff6b6b", "use": "counter-examples, traps (coral)" },
      "success":   { "hex": "#06d6a0", "use": "verification, QED (emerald)" },
      "text":      { "hex": "#c8ccdb", "use": "body narration (light slate)" },
      "muted":     { "hex": "#7e8497", "use": "retired / faded prior content" }
    },

    "brand": {
      "brand_red":        { "hex": "#BA0C2F", "use": "校門紅 — brand emphasis, section blocks" },
      "brand_red_bright": { "hex": "#e23a57", "use": "legible red for text on dark bg" },
      "brand_navy":       { "hex": "#16294E", "use": "藏青 — wordmark, headings on light frames" },
      "brand_gold":       { "hex": "#B6892B", "use": "點綴金 — summit star, brand accent" }
    },

    "brand_light_frame": {
      "paper_bg":      { "hex": "#eef1f6", "use": "intro / outro light-ground background" },
      "light_grid":    { "rgba": "rgba(22,41,78,0.045)", "use": "faint navy coordinate grid on light frames" },
      "heading":       { "hex": "#16294E", "use": "navy headline / wordmark on light" },
      "subtitle":      { "hex": "#5a6478", "use": "muted subtitle text on light" },
      "list_body":     { "hex": "#2b3242", "use": "list / body text on light" },
      "accent_on_light": { "hex": "#BA0C2F", "use": "eyebrows, numbering, dots, rules on light (brand red)" }
    },

    "support": {
      "hairline":  { "hex": "#243049", "use": "faint rules, ticks, borders (dark frames)" },
      "grid_line": { "rgba": "rgba(120,150,210,0.05)", "use": "background graph grid (dark frames), 80px cell" }
    }
  },

  "type": {
    "families": {
      "display": { "css": "'Space Grotesk'", "use": "headings, numerals, eyebrows", "google": true },
      "body":    { "css": "'Hanken Grotesk'", "use": "narration, captions", "google": true },
      "mono":    { "css": "'JetBrains Mono'", "use": "tags, axis labels, eyebrows", "google": true },
      "math":    { "css": "KaTeX / Computer Modern (serif)", "use": "all LaTeX math", "note": "rendered via KaTeX 0.16.9" }
    },
    "weights": { "display": [400,500,600,700], "body": [400,500,600,700], "mono": [400,500,600] },
    "scale_px_at_1920x1080": {
      "display":  104,
      "h1":       62,
      "h2":       46,
      "math":     46,
      "math_sm":  36,
      "body":     38,
      "step":     32,
      "eyebrow":  24,
      "label":    28
    },
    "scale_overrides_used_in_frames": {
      "intro_headline":  88,
      "intro_subtitle":  34,
      "transition_headline": 96,
      "outro_headline":  78
    },
    "eyebrow_style": { "letter_spacing": "0.32em", "text_transform": "uppercase", "weight": 500, "family": "mono" },
    "display_style": { "letter_spacing": "-0.015em", "line_height": 1.02, "weight": 600 },
    "body_style":    { "line_height": 1.5 }
  },

  "layout": {
    "safe_margin_px": 96,
    "side_gutter_px": 220,
    "heading_rule_width_px": 3,
    "grid_cell_px": 80,
    "content_column_pct": 77
  },

  "radii_and_strokes": {
    "math_card_radius_px": 4,
    "math_card_border": "1.5px solid #243049",
    "math_card_bg": "rgba(10,14,26,0.6)",
    "plot_dot_default_radius_px": 6,
    "summit_bar_width_px": 11,
    "summit_bar_gap_px": 6
  },

  "motifs": {
    "summit_bars": "7 ascending rounded bars (heights 0.32,0.56,0.78,1,0.78,0.56,0.32), center bar is the peak; optional gold star above center. Brand DNA, NOT the logo.",
    "plot_dot": "small filled circle bullet (coordinate-point motif)",
    "coordinate_grid": "80px square faint grid behind frames (math-plane motif)",
    "glow_accent": "text-shadow gold glow on the single emphasized key line (static stand-in for Manim flash)"
  },

  "emphasis_glow": {
    "glow_accent": "0 0 22px rgba(249,168,37,0.55), 0 0 6px rgba(249,168,37,0.35)",
    "glow_math":   "0 0 22px rgba(125,249,255,0.40), 0 0 6px rgba(125,249,255,0.25)"
  }
}
